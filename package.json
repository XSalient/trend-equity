{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:mock": "cross-env DEV_MOCK=true concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:live": "cross-env DEV_MOCK=false concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:debug:live": "cross-env DEV_MOCK=false concurrently \"tsx --inspect --watch server.ts\" \"npm run dev:client\"",
    "dev:debug:mock": "cross-env DEV_MOCK=true concurrently \"tsx --inspect --watch server.ts\" \"npm run dev:client\"",
    "dev:client": "vite --port=3000 --host=0.0.0.0",
    "dev:server": "tsx watch server.ts",
    "restart": "npm run dev",
    "restart:mock": "npm run dev:mock",
    "restart:live": "npm run dev:live",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run eslint && npm run format:check",
    "prepare": "husky",
    "build:android": "vite build --mode android && npx cap sync android",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "test:unit": "vitest run tests/unit",
    "test:unit:watch": "vitest tests/unit",
    "test:unit:coverage": "vitest run tests/unit --coverage",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:ui": "playwright test tests/e2e --ui",
    "test": "npm run test:unit && npm run test:e2e",
    "clean:ports": "powershell -Command \"Get-NetTCPConnection -LocalPort 3000, 3001, 3002 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }\"",
    "admin:list": "tsx scripts/manage-admin.ts list",
    "admin:grant": "tsx scripts/manage-admin.ts grant",
    "admin:revoke": "tsx scripts/manage-admin.ts revoke",
    "admin:info": "tsx scripts/manage-admin.ts info"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/node": "^5.6.18",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^2.1.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.2.0",
    "vitest": "^2.1.0"
  }
}

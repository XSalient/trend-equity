# =============================================================================
# Trend-Equity — Environment Variables Reference
# =============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# NEVER commit .env to git — it is listed in .gitignore.
# In production (Vercel), set these in the Vercel dashboard under
# Project → Settings → Environment Variables.
# =============================================================================


# -----------------------------------------------------------------------------
# GEMINI AI  (required)
# -----------------------------------------------------------------------------
# Your Google Gemini API key. Get one at https://aistudio.google.com/app/apikey
# Free tier: ~1,500 requests/day. Upgrade at console.cloud.google.com.
GEMINI_API_KEY=your_gemini_api_key_here


# -----------------------------------------------------------------------------
# DEV_MOCK  (local dev only — NEVER set in production)
# -----------------------------------------------------------------------------
# When "true", all Gemini API calls are bypassed and realistic mock data is
# returned from server.mocks.ts. Use this when your free-tier quota is
# exhausted or you want to develop offline.
#
#   npm run dev:mock   → starts with DEV_MOCK=true  (ignores this line)
#   npm run dev:live   → starts with DEV_MOCK=false (ignores this line)
#   npm run dev        → uses whatever is set here
#
# The server will refuse to start if DEV_MOCK=true AND NODE_ENV=production.
# Leave this unset (or "false") for normal local development against real API.
DEV_MOCK=false


# -----------------------------------------------------------------------------
# APP_URL  (required in production)
# -----------------------------------------------------------------------------
# The public URL of the deployed app. Used for CORS, OAuth callbacks, and
# self-referential API links.
# Locally you can leave this blank or set it to http://localhost:3000
APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# SYSTEM_PROMPT  (optional override)
# -----------------------------------------------------------------------------
# Override the default Gemini system prompt at runtime without code changes.
# Leave blank to use the default prompt defined in server.ts.
SYSTEM_PROMPT=


# -----------------------------------------------------------------------------
# Firebase — Frontend (Vite exposes VITE_* vars to the browser bundle)
# -----------------------------------------------------------------------------
# Get these from Firebase Console → Project Settings → General → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=


# -----------------------------------------------------------------------------
# Firebase Admin SDK — Server-side only (NEVER expose to browser)
# -----------------------------------------------------------------------------
# Used by Vercel serverless functions in api/ to verify auth tokens and write
# to Firestore server-side.

# Project ID — same value as VITE_FIREBASE_PROJECT_ID above
FIREBASE_PROJECT_ID=

# Service account key JSON (entire minified JSON as a single line).
# Generate at: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Store in Vercel env vars or Doppler. NEVER paste the raw file into this .env.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"YOUR_PROJECT"}

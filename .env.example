# Required: Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override system prompt
SYSTEM_PROMPT=

# Firebase (Vite exposes VITE_ prefixed vars to the browser frontend)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin SDK (server-side / Vercel serverless only)
# Project ID (same value as VITE_FIREBASE_PROJECT_ID)
FIREBASE_PROJECT_ID=trend-equity-63c48

# Service account key JSON — get from Firebase Console → Project Settings → Service Accounts
# Paste the entire JSON as a single line (minified). Store in Doppler, never commit.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

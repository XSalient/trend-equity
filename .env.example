# App environment variables
APP_URL=http://localhost:3000
DEV_MOCK=false

# Doppler (optional)
DOPPLER_CONFIG=dev
DOPPLER_ENVIRONMENT=dev
DOPPLER_PROJECT=trend-equity

# Firebase Client Configuration (Standard Vite variables)
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# Firebase Admin Configuration (Backend only)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"...","universe_domain":"..."}

# AI Configuration
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
SYSTEM_PROMPT=...

# Idea Quality Engine (all optional — safe defaults shown)
# Stronger judge model that scores/filters candidate ideas before publishing
GEMINI_CRITIC_MODEL=gemini-2.5-flash
# Minimum composite critic score (1-10) an idea needs to be published
QUALITY_MIN_SCORE=6.5
# Embedding model for semantic dedup vs the past 30 days of ideas
GEMINI_EMBED_MODEL=gemini-embedding-001
# Cosine similarity above which a candidate counts as a duplicate (0-1)
DEDUP_SIM_THRESHOLD=0.80
# Model for grounded market-evidence research (must be a Gemini 2.x model)
GEMINI_EVIDENCE_MODEL=gemini-2.5-flash

# Email Digest (Resend)
RESEND_API_KEY=re_...
CRON_SECRET=your-long-random-secret-token

# Daily Generation Cron Time (UTC, HH:MM format; cron runs at this time daily)
# Corresponds to cron schedule in vercel.json (e.g., "30 6" = 06:30 UTC)
VITE_DAILY_GENERATION_TIME=06:30

# Stripe Payment Processing
VITE_STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from Stripe Dashboard (created monthly recurring prices for Pro $9 and Builder $19)
STRIPE_PRICE_PRO=price_1TwAlRIdBbgqt2Le0cZpHTeQ
STRIPE_PRICE_BUILDER=price_1TwAlfIdBbgqt2LeUABAlTHP

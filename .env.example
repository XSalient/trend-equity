# Required: Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override system prompt (falls back to code default if missing)
SYSTEM_PROMPT=

# Required for caching & rate limiting (Vercel deployment only)
# Get these from https://console.upstash.com → Create Database → REST API tab
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Firebase (Vite exposes VITE_ prefixed vars to the browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# EditorConfig — https://editorconfig.org
# Supported natively by: JetBrains IDEs, Zed, Neovim
# Supported via plugin by: VSCode, Cursor, Windsurf (install EditorConfig extension)
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
# Preserve intentional trailing spaces (line breaks in Markdown)
trim_trailing_whitespace = false

[*.{json,jsonc}]
indent_size = 2

[Makefile]
indent_style = tab

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if current user is an admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check if current user is pro or builder tier
    function isProOrBuilder() {
      let userTier = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tier;
      return userTier == 'pro' || userTier == 'builder';
    }

    // ============ USER-OWNED COLLECTIONS ============

    // users/{uid} — user profile (tier, role, filters, settings)
    match /users/{uid} {
      allow read: if request.auth.uid == uid;
      allow create: if request.auth.uid == uid &&
                       !('tier' in request.resource.data) &&
                       !('role' in request.resource.data) &&
                       !('apiAccess' in request.resource.data);
      allow update: if request.auth.uid == uid &&
                       !('tier' in request.resource.data.diff.delta) &&
                       !('role' in request.resource.data.diff.delta) &&
                       !('apiAccess' in request.resource.data.diff.delta);
      allow delete: if false;
    }

    // user_saves/{saveId} — saved ideas
    match /user_saves/{saveId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // user_latest_idea/{uid} — latest custom idea analysis per user
    match /user_latest_idea/{uid} {
      allow read: if request.auth.uid == uid;
      allow create: if request.auth.uid == uid && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth.uid == uid && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // user_alerts/{alertId} — notifications for a user
    match /user_alerts/{alertId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.diff.delta.size() <= 1 &&
                       'isRead' in request.resource.data.diff.delta;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // user_digest_prefs/{uid} — email digest preferences
    match /user_digest_prefs/{uid} {
      allow write: if request.auth.uid == uid;
      allow read: if false;
      allow delete: if false;
    }

    // idea_reactions/{uid}_{ideaId} — user reactions (👍👎🔨)
    match /idea_reactions/{doc} {
      allow read: if request.auth != null && doc.split('_')[0] == request.auth.uid;
      allow create: if request.auth != null &&
                       request.resource.data.uid == request.auth.uid &&
                       doc.split('_')[0] == request.auth.uid;
      allow update: if request.auth != null &&
                       resource.data.uid == request.auth.uid &&
                       doc.split('_')[0] == request.auth.uid;
      allow delete: if request.auth != null &&
                       resource.data.uid == request.auth.uid &&
                       doc.split('_')[0] == request.auth.uid;
    }

    // ============ SHARED/PUBLIC COLLECTIONS ============

    // daily_generations/{date} — daily idea feed (singleton per date)
    match /daily_generations/{date} {
      allow read: if request.auth != null || resource.data.public == true;
      allow update: if request.auth != null && isAdmin();
      allow create, delete: if false;
    }

    // comments/{commentId} — idea discussion thread (read: all auth users, create: pro+ only)
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid && isProOrBuilder();
      allow update: if false;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // app_config/{doc} — global configuration (tier limits, feature flags)
    match /app_config/{doc} {
      allow read: if request.auth != null;
      allow write, delete: if false;
    }

    // te100/{id} — curated TE-100 projects (approved by admin)
    match /te100/{id} {
      allow read: if request.auth != null;
      allow write, delete: if false;
    }

    // te100_submissions/{submissionId} — user submissions for TE-100
    match /te100_submissions/{submissionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // ============ PUBLIC COLLECTIONS (LEAD GEN) ============

    // enterprise_leads — B2B lead capture (requires auth to submit)
    match /enterprise_leads/{leadId} {
      allow create: if request.auth != null &&
                       request.resource.data.keys().hasAll(['firstName', 'lastName', 'email', 'company', 'role']) &&
                       request.resource.data.email.matches('^[\\w\\.\\-+]+@[\\w\\.\\-]+$') &&
                       !('createdAt' in request.resource.data) &&
                       !('source' in request.resource.data) &&
                       !('userId' in request.resource.data);
      allow read, update, delete: if false;
    }

    // ============ SERVER-ONLY COLLECTIONS (DENY ALL CLIENT ACCESS) ============

    match /api_usage/{doc} { allow read, write, delete: if false; }
    match /api_cache/{doc} { allow read, write, delete: if false; }
    match /daily_generations_history/{doc} { allow read, write, delete: if false; }
    match /locks/{doc} { allow read, write, delete: if false; }
    match /idea_embeddings/{doc} { allow read, write, delete: if false; }
    match /idea_predictions/{doc} { allow read, write, delete: if false; }
    match /idea_stats/{doc} { allow read, write, delete: if false; }
    match /prompt_history/{doc} { allow read, write, delete: if false; }
    match /config/{doc} { allow read, write, delete: if false; }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write, delete: if false;
    }
  }
}

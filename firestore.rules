// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: daily_generations
// Document ID: YYYY-MM-DD
// Fields:
//   - date: string (required)
//   - ideas: array of objects (required)
//   - generatedAt: string ISO date (required)
//
// Collection: user_saves
// Document ID: auto-generated
// Fields:
//   - userId: string (required)
//   - idea: object (required)
//   - savedAt: timestamp (required)
//   - updatedAt: timestamp (optional)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUserSave(data) {
      return data.userId is string &&
             data.idea is map &&
             data.savedAt is timestamp &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidUserSaveUpdate(data, prevData) {
      return data.userId == prevData.userId &&
             data.savedAt == prevData.savedAt &&
             data.idea is map &&
             data.updatedAt == request.time;
    }

    // Profile update: allows changing filters and other fields
    // FIX (S-9): The `tier` field CANNOT be changed by the client.
    // Tier changes must be performed server-side via Admin SDK after payment verification.
    function isValidProfileUpdate(data, existingData) {
      // If tier is present in the update, it must not change
      return (!('tier' in data) || data.tier == existingData.tier) &&
             data.updatedAt is timestamp;
    }

    // New profile creation: only allowed with 'free' tier
    function isValidProfileCreate(data) {
      return data.updatedAt is timestamp &&
             (!('tier' in data) || data.tier == 'free');
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      // FIX (S-9): Create only with free tier; update cannot change tier
      allow create: if isOwner(userId) && isValidProfileCreate(request.resource.data);
      allow update: if isOwner(userId) && isValidProfileUpdate(request.resource.data, resource.data);
      allow delete: if false;
    }

    match /daily_generations/{date} {
      // Anyone can read daily generations (public feed)
      allow read: if true;
      // FIX (S-8, B-2): Only server-side Admin SDK writes daily_generations
      // (Admin SDK bypasses these rules entirely; setting to false prevents
      // any malicious client from injecting a fake daily feed)
      allow create, update, delete: if false;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.ideaId is string &&
                      request.resource.data.text is string &&
                      request.resource.data.text.size() > 0 &&
                      request.resource.data.text.size() <= 500;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /user_saves/{saveId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid &&
                      isValidUserSave(request.resource.data);
      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid &&
                      isValidUserSaveUpdate(request.resource.data, resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /api_usage/{docId} {
      // Only server-side Admin SDK reads/writes usage docs
      allow read, write: if false;
    }

    match /api_cache/{docId} {
      // Only server-side Admin SDK reads/writes cache docs
      allow read, write: if false;
    }
  }
}

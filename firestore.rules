// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: daily_generations
// Document ID: YYYY-MM-DD
// Fields:
//   - date: string (required)
//   - ideas: array of objects (required)
//   - generatedAt: timestamp (required)
//
// Collection: user_saves
// Document ID: auto-generated
// Fields:
//   - userId: string (required)
//   - idea: object (required)
//   - savedAt: timestamp (required)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidDailyGeneration(data) {
      return data.date is string &&
             data.ideas is list &&
             data.generatedAt == request.time;
    }

    function isValidUserSave(data) {
      return data.userId is string &&
             data.idea is map &&
             data.savedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /daily_generations/{date} {
      // Anyone can read daily generations (public feed)
      allow read: if true;
      // Anyone can trigger today's generation if it doesn't exist yet.
      // This handles the "first visitor of the day" case gracefully.
      // Once created, it cannot be updated or deleted (idempotent).
      allow create: if isValidDailyGeneration(request.resource.data) && 
                      request.resource.data.date == date;
      // No updates or deletes for daily generations
      allow update, delete: if false;
    }

    match /user_saves/{saveId} {
      // Users can only read their own saves
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Users can create their own saves
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid &&
                      isValidUserSave(request.resource.data);
      // Users can delete their own saves
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // No updates for saves
      allow update: if false;
    }
  }
}
